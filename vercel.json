{
  "redirects": [
    {
      "source": "/location/kashipur",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/location/kashipur/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/location/:slug",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/location/:slug/:rest*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/news/:rest*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/profile/:rest*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tour/:rest*",
      "destination": "/packages",
      "permanent": true
    },
    {
      "source": "/tours/:rest*",
      "destination": "/packages",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
